# ArgoCD base URL - empty for same-origin (production via nginx proxy)
# For development, the Vite proxy in vite.config.ts handles forwarding.
# Options: https://argocd.diamond.ac.uk or https://argocd-controls.diamond.ac.uk
VITE_ARGOCD_BASE_URL=

# ArgoCD auth token for development
# Log in to https://argocd.diamond.ac.uk, then copy the 'argocd.token' cookie
# from DevTools > Application > Cookies
ARGOCD_AUTH_TOKEN=

# Optional: filter to a specific ArgoCD project
VITE_ARGOCD_PROJECT=

# Auto-refresh interval in milliseconds (default: 30000)
VITE_REFRESH_INTERVAL=30000
