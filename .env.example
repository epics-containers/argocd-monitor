# ArgoCD auth token for development
# Run: argocd login argocd.diamond.ac.uk --grpc-web --sso
# Then copy auth-token from ~/.config/argocd/config
ARGOCD_AUTH_TOKEN=

# Optional: filter to a specific ArgoCD project
VITE_ARGOCD_PROJECT=

# ArgoCD hostname shown in login instructions (default: argocd.diamond.ac.uk)
# VITE_ARGOCD_HOST=argocd.diamond.ac.uk

# Base URL prefix for API requests (default: "" = same origin)
# VITE_ARGOCD_BASE_URL=

# Auto-refresh interval in milliseconds (default: 30000)
VITE_REFRESH_INTERVAL=30000
