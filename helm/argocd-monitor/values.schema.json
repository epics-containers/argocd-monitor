{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "argocd-monitor Helm chart",
    "description": "Helm chart for deploying an ArgoCD monitoring dashboard",
    "type": "object",
    "properties": {
        "argocd": {
            "type": "object",
            "properties": {
                "url": {
                    "description": "The ArgoCD instance URL to proxy API requests to",
                    "type": "string"
                }
            },
            "additionalProperties": false
        },
        "global": {
            "description": "Global values shared between all subcharts",
            "$comment": "Added automatically by 'helm schema' to allow this chart to be used as a Helm dependency, as the `additionalProperties` setting would otherwise collide with Helm's special 'global' values key.",
            "type": [
                "object",
                "null"
            ]
        },
        "image": {
            "type": "object",
            "properties": {
                "pullPolicy": {
                    "description": "Image pull policy",
                    "type": "string",
                    "enum": [
                        "Always",
                        "IfNotPresent",
                        "Never"
                    ]
                },
                "repository": {
                    "description": "Container image repository",
                    "type": "string"
                },
                "tag": {
                    "description": "Image tag (defaults to Chart.appVersion)",
                    "type": "string"
                }
            },
            "additionalProperties": false
        },
        "ingress": {
            "type": "object",
            "properties": {
                "annotations": {
                    "description": "Ingress annotations",
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "className": {
                    "description": "Ingress class name",
                    "type": "string"
                },
                "enabled": {
                    "description": "Enable Ingress resource",
                    "type": "boolean"
                },
                "host": {
                    "description": "Ingress hostname",
                    "type": "string"
                },
                "tls": {
                    "description": "TLS configuration",
                    "type": "array"
                }
            },
            "additionalProperties": false
        },
        "nodeSelector": {
            "description": "Node selector for pod scheduling",
            "type": "object",
            "additionalProperties": {
                "type": "string"
            }
        },
        "oauth2Proxy": {
            "type": "object",
            "properties": {
                "clientId": {
                    "description": "OIDC client ID registered in Keycloak",
                    "type": "string"
                },
                "enabled": {
                    "description": "Enable oauth2-proxy sidecar for Keycloak OIDC authentication",
                    "type": "boolean"
                },
                "existingSecret": {
                    "description": "Name of existing K8s Secret with keys client-secret and cookie-secret",
                    "type": "string"
                },
                "extraArgs": {
                    "description": "Additional command-line arguments for oauth2-proxy",
                    "type": "array"
                },
                "image": {
                    "type": "object",
                    "properties": {
                        "pullPolicy": {
                            "description": "oauth2-proxy image pull policy",
                            "type": "string",
                            "enum": [
                                "Always",
                                "IfNotPresent",
                                "Never"
                            ]
                        },
                        "repository": {
                            "description": "oauth2-proxy container image repository",
                            "type": "string"
                        },
                        "tag": {
                            "description": "oauth2-proxy image tag",
                            "type": "string"
                        }
                    },
                    "additionalProperties": false
                },
                "issuerUrl": {
                    "description": "OIDC issuer URL (e.g. https://identity.example.com/realms/myrealm)",
                    "type": "string"
                },
                "resources": {
                    "type": "object",
                    "properties": {
                        "limits": {
                            "type": "object",
                            "properties": {
                                "cpu": {
                                    "description": "oauth2-proxy CPU limit",
                                    "type": "string"
                                },
                                "memory": {
                                    "description": "oauth2-proxy memory limit",
                                    "type": "string"
                                }
                            },
                            "additionalProperties": false
                        },
                        "requests": {
                            "type": "object",
                            "properties": {
                                "cpu": {
                                    "description": "oauth2-proxy CPU request",
                                    "type": "string"
                                },
                                "memory": {
                                    "description": "oauth2-proxy memory request",
                                    "type": "string"
                                }
                            },
                            "additionalProperties": false
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        },
        "replicaCount": {
            "description": "Number of pod replicas",
            "type": "integer",
            "minimum": 1
        },
        "resources": {
            "type": "object",
            "properties": {
                "limits": {
                    "type": "object",
                    "properties": {
                        "cpu": {
                            "description": "CPU limit",
                            "type": "string"
                        },
                        "memory": {
                            "description": "Memory limit",
                            "type": "string"
                        }
                    },
                    "additionalProperties": false
                },
                "requests": {
                    "type": "object",
                    "properties": {
                        "cpu": {
                            "description": "CPU request",
                            "type": "string"
                        },
                        "memory": {
                            "description": "Memory request",
                            "type": "string"
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        },
        "service": {
            "type": "object",
            "properties": {
                "port": {
                    "description": "Service port",
                    "type": "integer"
                },
                "type": {
                    "description": "Kubernetes Service type",
                    "type": "string",
                    "enum": [
                        "ClusterIP",
                        "LoadBalancer",
                        "NodePort"
                    ]
                }
            },
            "additionalProperties": false
        },
        "tolerations": {
            "description": "Tolerations for pod scheduling",
            "type": "array"
        }
    },
    "additionalProperties": false
}
